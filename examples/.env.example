# SST Environment Variables

ACOUSTID_API_KEY=your_acoustid_key_here

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# SeaweedFS S3 Storage
# SeaweedFS S3 APIはバケット名を /buckets/<バケット名> というパスにマッピングします。
# S3_BUCKET=sst と設定した場合、保存先は /buckets/sst/... となり、S3の一般的なベストプラクティスに沿った形になります。
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_BUCKET=sst

# VGMdb Browser-use LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OPENAI_API_KEY=
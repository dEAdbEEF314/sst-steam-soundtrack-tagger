# SST Scout - Environment Variables
#
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ---- Steam Library ----
# Path to your Steam library root directory (contains "steamapps/" folder).
#
# Docker Desktop for Windows — use Windows path format:
#   STEAM_LIBRARY_PATH=C:\Program Files (x86)\Steam
#
# WSL2 / Linux — use Linux path format:
#   STEAM_LIBRARY_PATH=/mnt/c/Program Files (x86)/Steam
#
# Secondary library (e.g. extra HDD):
#   STEAM_LIBRARY_PATH=D:\SteamLibrary
STEAM_LIBRARY_PATH=C:\Program Files (x86)\Steam

# ---- SeaweedFS S3 Storage ----
S3_ENDPOINT_URL=http://swfs-s3.outergods.lan
S3_BUCKET=buckets
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Options ----
# Set to "true" to log what would be uploaded without touching S3.
DRY_RUN=false

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

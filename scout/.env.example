# SST Scout - Environment Variables (Example)
#
# このファイルを .env にコピーして、値を入力してください。
# cp .env.example .env

# ---- Steam Library ----
# Steam ライブラリのルートディレクトリ（"steamapps/" を含むパスを指定）
STEAM_LIBRARY_PATH=C:\Program Files (x86)\Steam

# ---- SeaweedFS S3 Storage ----
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=sst
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ---- LLM Configuration (Metadata Resolver) ----
# 使用するプロバイダー: ollama, google-genai, openai
LLM_PROVIDER=ollama

# Ollama 設定
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5-coder:14b

# 外部 LLM 用 API キー (Gemini / OpenAI 等)
LLM_API_KEY=your-api-key-here

# ---- VGMdb / Search API (Optional) ----
# Cloudflare 回避用のクッキーが必要な場合に使用（省略可）
# VGMDB_USER_COOKIE=

# Fallback Search API 用 (Google Custom Search 等を使用する場合、省略可)
# GOOGLE_API_KEY=
# CUSTOM_SEARCH_ENGINE_ID=

# ---- Operation Options ----
DRY_RUN=false
LOG_LEVEL=INFO
